---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const novels = await getCollection('novels');
  return novels.map((novel) => ({
    params: { slug: novel.id.split('/')[0] },
    props: { novel },
  }));
}

const { novel } = Astro.props;
const slug = novel.id.split('/')[0];

// Page images live next to the novel's meta.yaml; filename order = page order.
const allPages = import.meta.glob<{ default: ImageMetadata }>(
  '../../content/novels/*/pages/*.{jpg,jpeg,png,webp,svg}',
  { eager: true }
);

const pages = Object.entries(allPages)
  .filter(([path]) => path.includes(`/novels/${slug}/pages/`))
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);
---

<Base
  title={`${novel.data.title} — Louella`}
  description={novel.data.blurb}
>
  <article>
    <header>
      <h1>{novel.data.title}</h1>
      <p class="meta">
        {novel.data.year} · {novel.data.status} · {pages.length} pages
      </p>
      <p class="blurb">{novel.data.blurb}</p>
    </header>

    <!-- Simple scroll reader for now; the page-turn reader lands in Phase 3. -->
    <div class="pages">
      {
        pages.map((page, i) => (
          <figure>
            <Image
              src={page}
              alt={`${novel.data.title}, page ${i + 1}`}
              widths={[800, 1400]}
              sizes="(max-width: 900px) 96vw, 820px"
              loading={i < 2 ? 'eager' : 'lazy'}
            />
            <figcaption class="meta">
              {i + 1} / {pages.length}
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p class="back"><a href="/novels/">← Back to the shelf</a></p>
  </article>
</Base>

<style>
  header {
    text-align: center;
    max-width: 38rem;
    margin: 0 auto 2rem;
  }

  h1 {
    margin-bottom: 0.2rem;
  }

  .pages {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 820px;
    margin: 0 auto;
  }

  figure {
    margin: 0;
    border: var(--line);
    border-radius: var(--wobble-sm);
    overflow: hidden;
    background: white;
  }

  figcaption {
    text-align: center;
    padding: 0.4rem;
  }

  .back {
    text-align: center;
    padding-top: 2rem;
  }
</style>
